# BusyBox configuration for WishOS packages
# Optimized for static builds with common utilities

# Build options
CONFIG_STATIC=y

# Core utilities
CONFIG_BASENAME=y
CONFIG_CAT=y
CONFIG_CHGRP=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_CP=y
CONFIG_CUT=y
CONFIG_DATE=y
CONFIG_DD=y
CONFIG_DF=y
CONFIG_DIRNAME=y
CONFIG_DU=y
CONFIG_ECHO=y
CONFIG_ENV=y
CONFIG_EXPAND=y
CONFIG_EXPR=y
CONFIG_FALSE=y
CONFIG_FILE=y
CONFIG_FIND=y
CONFIG_FOLD=y
CONFIG_GETOPT=y
CONFIG_GREP=y
CONFIG_HEAD=y
CONFIG_ID=y
CONFIG_INSTALL=y
CONFIG_KILL=y
CONFIG_LENGTH=y
CONFIG_LN=y
CONFIG_LS=y
CONFIG_MD5SUM=y
CONFIG_MKDIR=y
CONFIG_MKFIFO=y
CONFIG_MKNOD=y
CONFIG_MKTEMP=y
CONFIG_MV=y
CONFIG_OD=y
CONFIG_PASTE=y
CONFIG_PRINTF=y
CONFIG_PWD=y
CONFIG_READLINK=y
CONFIG_RM=y
CONFIG_RMDIR=y
CONFIG_SHA1SUM=y
CONFIG_SHA256SUM=y
CONFIG_SHRED=y
CONFIG_SORT=y
CONFIG_STAT=y
CONFIG_SYNC=y
CONFIG_TAIL=y
CONFIG_TAR=y
CONFIG_TOUCH=y
CONFIG_TR=y
CONFIG_TRUE=y
CONFIG_UNAME=y
CONFIG_UNIQ=y
CONFIG_USLEEP=y
CONFIG_WC=y
CONFIG_WHICH=y
CONFIG_YES=y

# Text processing
CONFIG_SED=y
CONFIG_AWK=y

# Archive/compression support in tar
CONFIG_FEATURE_TAR_GZIP=y
CONFIG_FEATURE_TAR_BZIP2=y
CONFIG_FEATURE_TAR_XZ=y

# Networking - disable tc to avoid CBQ kernel header issues
CONFIG_TC=n

# Shell
CONFIG_SH_IS_ASH=y
CONFIG_FEATURE_SH_IS_ASH=y
CONFIG_ASH=y
CONFIG_ASH_OPTIMIZE_FOR_SIZE=y

# Disable various problematic features
CONFIG_FEATURE_EDITING=y
CONFIG_FEATURE_EDITING_HISTORY=255
CONFIG_FEATURE_EDITING_SAVEHISTORY=y
CONFIG_FEATURE_TAB_COMPLETION=y
